# Avalon server environment. Copy to `server/.env` and fill in real values.
# `.env` is gitignored; this example is committed. Never put real secrets here.

# --- Core ---
PORT=4000
# MongoDB connection. Local default below, OR a hosted cluster (no local install,
# no admin, deploy-ready). For MongoDB Atlas use the SRV form:
#   MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/avalon?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/avalon
CLIENT_ORIGIN=http://localhost:3000

# --- Admin gate ---
# Required by content publishing (POST/PUT /api/content) and on-chain deposits
# (POST /api/users/demo/gateway-deposit). Fail-closed: unset -> those endpoints
# return 503. Pick any long random string; enter it in the UI when prompted.
ADMIN_TOKEN=choose-a-long-random-string

# --- Payments ---
# "mock" debits a mock USD/USDC balance (no chain, no signing) and is the fastest
# way to see the meter + agent. "circle" routes through Circle Gateway on Arc
# testnet with real signing and batched settlement (fully wired). For circle,
# fill in the Circle + DeepSeek vars below and deposit into Gateway first.
PAYMENT_MODE=mock

# --- Circle Gateway (only needed when PAYMENT_MODE=circle) ---
# Full developer API key in PREFIX:ID:SECRET form, e.g. TEST_API_KEY:<id>:<secret>.
CIRCLE_API_KEY=TEST_API_KEY:your_key_id:your_key_secret
CIRCLE_GATEWAY_BASE_URL=https://gateway-api-testnet.circle.com
CIRCLE_GATEWAY_ENV=testnet
# Seller/creator wallet that batched settlements pay to (the `to` in the EIP-3009 authorization).
CIRCLE_SELLER_WALLET=0xYOUR_SELLER_WALLET
CIRCLE_SUPPORTED_CHAIN=arc-testnet

# --- Step 4: Circle developer-controlled wallet signer ---
# Registered 32-byte hex entity secret for @circle-fin/developer-controlled-wallets.
# Register first: https://developers.circle.com/wallets/dev-controlled/register-entity-secret
CIRCLE_ENTITY_SECRET=your_registered_entity_secret_hex
CIRCLE_WALLET_SET_ID=your_wallet_set_id
# Buyer EOA wallet (created on ARC-TESTNET) that signs the EIP-3009 authorizations.
CIRCLE_BUYER_WALLET_ID=your_buyer_wallet_id
CIRCLE_BUYER_ADDRESS=0xYOUR_BUYER_ADDRESS

# Arc block explorer (Blockscout) for the verify-on-chain links on the
# Transactions and Top up pages. Defaults shown; override per chain/deploy.
ARC_EXPLORER_URL=https://testnet.arcscan.app
ARC_CHAIN_ID=5042002

# --- Step 5: Ember, the budget agent (DeepSeek model, OpenAI-compatible) ---
# AGENT_REASONING gates the model path; "false" -> deterministic guards only.
AGENT_REASONING=false
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Optional: in-loop model timeout (ms) and decision cache window (ms).
AGENT_TIMEOUT_MS=2500
AGENT_CACHE_MS=15000

# --- Allowance / settlement tuning (optional; defaults shown, atomic USDC / ms) ---
# Fallback per-session cap when the client sends no chosen amount (the UI lets the
# user pick a cap, so this is only a backstop). 60000 = $0.06.
SESSION_CAP_ATOMIC=60000
# Flush a batch once pending crosses the threshold or the interval elapses.
SETTLEMENT_FLUSH_THRESHOLD_ATOMIC=50000
SETTLEMENT_FLUSH_INTERVAL_MS=60000

# --- Tests (optional; defaults point at local Mongo with dedicated DBs) ---
# Each suite uses its own DB so they can run in parallel and drop on teardown.
# These can also point at a hosted cluster (distinct DB names per suite); on a
# remote DB the suites' 2s serverSelectionTimeoutMS may be tight on first connect.
MONGODB_TEST_URI=mongodb://127.0.0.1:27017/avalon_allowance_test
MONGODB_TEST_URI_METER=mongodb://127.0.0.1:27017/avalon_meter_test
MONGODB_TEST_URI_SETTLE=mongodb://127.0.0.1:27017/avalon_settlement_test
